# ---- LLM provider ----
# Which provider to use: openai | anthropic | gemini | ollama
LLM_PROVIDER=

# Model name (provider-specific, e.g. gpt-4o-mini, claude-sonnet-4-5, gemini-2.0-flash, llama3.1)
LLM_MODEL=

# Max tokens for LLM response
LLM_MAX_TOKENS=

# ---- API keys (set only the one matching LLM_PROVIDER) ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ---- Ollama (only if LLM_PROVIDER=ollama) ----
OLLAMA_BASE_URL=

# ---- MongoDB (required) ----
MONGO_URI=
MONGO_DB_NAME=

# ---- Cache ----
# TTL in seconds (0 = disabled)
CACHE_TTL=
# How often (seconds) to sweep expired cache entries
CACHE_CLEAN_INTERVAL=
